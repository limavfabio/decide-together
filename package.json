{
  "name": "decide-together",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "pnpm build && vite preview",
    "deploy": "pnpm build && wrangler deploy workers/deploy.ts",
    "typegen": "wrangler types && react-router typegen",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply decide-together --local",
    "db:migrate:remote": "wrangler d1 migrations apply decide-together --remote",
    "test": "vitest run",
    "typecheck": "pnpm typegen && tsc"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.17.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.42",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "7.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@react-router/dev": "7.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
